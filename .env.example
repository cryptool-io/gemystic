# ─── Site ────────────────────────────────────────────────────────────────────
# Must be set in production: canonical URLs, sitemap, JSON-LD and llms.txt all
# derive from it. Config validation errors if this is still localhost in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Powers the customer assistant, auto-listing and the written financial analysis.
# Everything else — storefront, catalogue, SEO, all computed finance figures —
# works without it.
ANTHROPIC_API_KEY=

# ─── Database (PostgreSQL — required for orders, users, admin CRUD) ─────────
# Local:  docker compose --profile db up -d   then run: npm run db:migrate
# The JSON stores keep working without it; each store swaps to Prisma when set.
DATABASE_URL=postgresql://gem:gem@localhost:5432/gemystic

# ─── Email ───────────────────────────────────────────────────────────────────
# file = write .eml to var/outbox (default, no credentials needed)
# smtp = any relay, including SES's SMTP endpoint  (npm i nodemailer)
# ses  = AWS SES v2 API                            (npm i @aws-sdk/client-sesv2)
MAIL_DRIVER=file
MAIL_FROM="Gemystic Gems <no-reply@gemysticgems.com>"
MAIL_TO=Info@gemysticgems.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

SES_CONFIGURATION_SET=

# ─── Media storage ───────────────────────────────────────────────────────────
# local = var/uploads, served via /media   |   s3 = bucket (npm i @aws-sdk/client-s3)
STORAGE_DRIVER=local
S3_BUCKET=
S3_PREFIX=media/
S3_PUBLIC_BASE_URL=

# ─── Backups ─────────────────────────────────────────────────────────────────
# local writes to var/backups. s3 ALSO pushes offsite — this is the phase that
# actually protects against disk failure, so bring it forward if nothing else.
BACKUP_DRIVER=local
BACKUP_RETAIN_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=backups/

# ─── AWS ─────────────────────────────────────────────────────────────────────
# Only read when a driver above is set to an AWS one. Prefer an instance role
# over static keys — the adapters use the default credential chain, so a role
# needs no configuration here at all.
AWS_REGION=eu-west-1

# ─── Paths (override for containerised deploys) ──────────────────────────────
# DATA_DIR=./data
# VAR_DIR=./var
# UPLOAD_DIR=./var/uploads
# OUTBOX_DIR=./var/outbox
# BACKUP_DIR=./var/backups
