{
  "name": "gemystic-marketplace",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "chrome >= 90",
    "edge >= 90",
    "firefox >= 88",
    "safari >= 14"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:import-stores": "tsx scripts/import-stores.ts",
    "seed:order": "tsx scripts/seed-order.ts",
    "grant:admin": "tsx scripts/grant-admin.ts",
    "gemystic:sync": "node scripts/gemysticgems-sync.mjs",
    "normalize": "node scripts/normalize.mjs",
    "backup": "node scripts/backup.mjs",
    "restore": "node scripts/restore.mjs",
    "admin": "node scripts/admin.mjs",
    "etsy:sync": "node scripts/etsy-sync.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.0",
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "google-auth-library": "^10.9.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "pg": "^8.22.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.0",
    "prisma": "^6.16.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2"
  }
}
